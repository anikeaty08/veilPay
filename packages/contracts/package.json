{
  "name": "@veilpay/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "VeilPay confidential payouts and payroll contracts on Fhenix CoFHE",
  "scripts": {
    "clean": "rimraf artifacts cache coverage typechain-types deployments/localcofhe",
    "compile": "node scripts/run-hardhat.js compile",
    "test": "node scripts/run-hardhat.js test",
    "deploy": "node scripts/run-hardhat.js run scripts/deploy.ts",
    "deploy:eth-sepolia": "node scripts/run-hardhat.js run scripts/deploy.ts --network eth-sepolia",
    "deploy:arb-sepolia": "node scripts/run-hardhat.js run scripts/deploy.ts --network arb-sepolia",
    "localcofhe:test": "node scripts/run-hardhat.js test --network localcofhe"
  },
  "license": "MIT",
  "devDependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.0.13",
    "@fhenixprotocol/cofhe-mock-contracts": "^0.3.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.1",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "chai": "^4.2.0",
    "cofhe-hardhat-plugin": "^0.3.1",
    "cofhejs": "^0.3.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.4.0",
    "hardhat": "^2.22.19",
    "hardhat-gas-reporter": "^1.0.8",
    "rimraf": "^6.0.1",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.0",
    "typescript": ">=4.5.0"
  }
}
