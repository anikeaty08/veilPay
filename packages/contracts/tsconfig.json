{
  "compilerOptions": {
    "target": "es2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "./hardhat.config.ts",
    "./scripts",
    "./test",
    "./tasks"
  ]
}
